{
  "name": "antigravity-pdf-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:dev": "vite build --mode development && electron-builder --win --dir",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "build:linux": "vite build && electron-builder --linux",
    "lint": "eslint .",
    "preview": "vite preview",
    "gen:icon": "node scripts/generate-ico.mjs"
  },
  "build": {
    "appId": "com.toobee.pdf-studio",
    "productName": "TooBee PDF Studio",
    "icon": "./build/icon.ico",
    "afterPack": "scripts/afterPack.cjs",
    "directories": {
      "output": "dist",
      "app": "."
    },
    "win": {
      "icon": "./build/icon.ico",
      "executableName": "TooBeePDFStudio",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TooBee PDF Studio"
    },
    "files": [
      "dist-renderer/**/*",
      "dist-electron/**/*",
      "./build/icon.ico"
    ],
    "extraResources": [
      {
        "from": "./build/icon.ico",
        "to": "icon.ico"
      }
    ]
  },
  "dependencies": {
    "@pdfsmaller/pdf-encrypt-lite": "^1.0.2",
    "framer-motion": "^11.3.30",
    "jszip": "^3.10.1",
    "lucide-react": "^0.428.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.5.136",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-router-dom": "^6.26.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.4.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.23.1",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.5",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}