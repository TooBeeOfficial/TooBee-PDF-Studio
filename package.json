{
  "name": "toobee-pdf-studio",
  "private": true,
  "version": "1.0.0",
  "description": "TooBee PDF Studio",
  "author": "TooBee",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:dev": "vite build --mode development && electron-builder --win --dir",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "build:linux": "vite build && electron-builder --linux",
    "lint": "eslint .",
    "preview": "vite preview",
    "gen:icon": "node scripts/generate-ico.mjs"
  },
  "build": {
    "productName": "TooBee PDF Studio",
    "appId": "com.toobee.pdf-studio",
    "icon": "./build/icon.ico",
    "directories": {
      "output": "dist",
      "app": "."
    },
    "win": {
      "icon": "./build/icon.ico",
      "executableName": "TooBeePDFStudio",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TooBee PDF Studio"
    },
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "role": "Editor"
      },
      {
        "ext": "png",
        "name": "PNG Image",
        "role": "Editor"
      },
      {
        "ext": "jpg",
        "name": "JPEG Image",
        "role": "Editor"
      },
      {
        "ext": "jpeg",
        "name": "JPEG Image",
        "role": "Editor"
      },
      {
        "ext": "docx",
        "name": "Word Document",
        "role": "Editor"
      },
      {
        "ext": "xlsx",
        "name": "Excel Document",
        "role": "Editor"
      },
      {
        "ext": "txt",
        "name": "Text Document",
        "role": "Editor"
      }
    ],
    "files": [
      "dist-renderer/**/*",
      "dist-electron/**/*"
    ]
  },
  "dependencies": {
    "@pdfsmaller/pdf-encrypt-lite": "^1.0.2",
    "framer-motion": "^11.3.30",
    "html2canvas": "^1.4.1",
    "i18next": "^26.0.8",
    "jszip": "^3.10.1",
    "lucide-react": "^0.428.0",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.5.136",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^6.26.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.4.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.23.1",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.5",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}